  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "contact": {
    "homepage": "https://ampere.gtlugo.com/",
    "sources": "https://github.com/GTLugo/ampere"
  },
  "license": "${mod_license}",
  "icon": "logo-large.png",
  "environment": "*",
