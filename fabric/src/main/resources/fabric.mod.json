{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "contact": {
    "homepage": "https://ampere.gtlugo.com/",
    "sources": "https://github.com/GTLugo/ampere"
  },
  "license": "${mod_license}",
  "icon": "logo-large.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "${maven_group}.fabric.${mod_name}Fabric"
    ],
    "client": [
      "${maven_group}.fabric.client.${mod_name}FabricClient"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.10",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "architectury": ">=13.0.8",
    "fabric-api": "*"
  }
}
